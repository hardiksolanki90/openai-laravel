{
    "name": "hardiksolanki/openai-laravel",
    "description": "Production-ready Laravel package for OpenAI API integration with database persistence, multi-tenancy, and team management.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "openai", "gpt", "ai", "chatgpt", "saas", "multi-tenancy"],
    "authors": [
        {
            "name": "Hardik Solanki",
            "email": "hardiksolanki811@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/console": "^10.0|^11.0",
        "openai-php/client": "^0.10",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "HardikSolanki\\OpenAILaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HardikSolanki\\OpenAILaravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HardikSolanki\\OpenAILaravel\\OpenAIServiceProvider"
            ],
            "aliases": {
                "OpenAI": "HardikSolanki\\OpenAILaravel\\Facades\\OpenAI"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    }
}
